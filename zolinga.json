{
  "name": "Zolinga CMS",
  "version": "1.6.1",
  "description": "File-based CMS.",
  "authors": [
    "Daniel Sevcik <danny@zolinga.net>"
  ],
  "attributes": {},
  "listen": [
    {
      "description": "CMS Service.",
      "service": "cms",
      "class": "\\Zolinga\\Cms\\PageServer",
      "origin": [
        "*"
      ]
    },
    {
      "description": "CMS Content Parser",
      "service": "cmsParser",
      "class": "\\Zolinga\\Cms\\ContentParser",
      "origin": [
        "*"
      ]
    },
    {
      "description": "CMS server.",
      "event": "system:content",
      "class": "\\Zolinga\\Cms\\PageServer",
      "method": "onContent",
      "origin": [
        "remote"
      ]
    },
    {
      "description": "Replace variables in content. Supports: {{GET:*}}, {{POST:*}}",
      "event": "cms:content:replace-vars",
      "class": "\\Zolinga\\Cms\\ReplaceVarsListener",
      "method": "onReplaceVars",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "Choose random matching nodes from the element content.",
      "event": "cms:content:random-chooser",
      "class": "\\Zolinga\\Cms\\RandomChooserListener",
      "method": "onRandomChooser",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "CMS page.",
      "event": "cms:content:include-file",
      "class": "\\Zolinga\\Cms\\IncludeFile",
      "method": "onIncludeFile",
      "origin": [
        "*"
      ]
    }, 
    {
      "description": "CMS Tree representation.",
      "service": "cmsTree",
      "class": "\\Zolinga\\Cms\\Tree\\TreeRoot",
      "origin": [
        "*"
      ]
    },
    {
      "description": "CMS page menu.",
      "event": "cms:content:cms-menu",
      "class": "\\Zolinga\\Cms\\PageMenu",
      "method": "onCmsMenu",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "Adds CMS Elements Article to :ref WIKI page.",
      "event": "system:wiki:ref:discovery",
      "class": "\\Zolinga\\Cms\\WikiCmsElements",
      "method": "onWikiRefDiscovery",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "Applies XSLT transformation to inner content of <transform-content> tag.",
      "event": "cms:content:transform-content",
      "class": "\\Zolinga\\Cms\\TransformContentListener",
      "method": "onTransformContent",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "Converts Markdown inner content to HTML using Parsedown.",
      "event": "cms:content:markdown-to-html",
      "class": "\\Zolinga\\Cms\\MarkdownToHtmlElement",
      "method": "onMarkdownToHtml",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "Converts HTML inner content to Markdown using XSLT.",
      "event": "cms:content:html-to-markdown",
      "class": "\\Zolinga\\Cms\\HtmlToMarkdownElement",
      "method": "onHtmlToMarkdown",
      "origin": [
        "internal"
      ]
    }
  ],
  "emit": [
    {
      "description": "Parse custom HTML element.",
      "event": "cms:content:*",
      "class": "\\Zolinga\\Cms\\Events\\ContentElementEvent",
      "origin": [
        "internal"
      ]
    }
  ],
  "webComponents": [
    {
      "tag": "cms-menu",
      "description": "CMS menu.",
      "module": "web-components/cms-menu/cms-menu.js"
    }
  ],
  "autoload": {
    "Zolinga\\Cms\\": "src/"
  },
  "config": {
    "cms": {
      "# menuCache": "false: disalbe caching of menu structure. All .html files will be scanned on each request. Only for development.",
      "menuCache": true
    }
  }
}